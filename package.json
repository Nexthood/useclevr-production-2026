{
  "name": "useclever-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port ${PORT:-3000}",
    "build": "next build --webpack",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-8080}",
    "start:min": "next start --hostname 0.0.0.0 --port ${PORT:-8080} 2>&1 | grep -E --line-buffered '(http://|https://|Local:|Network:|Ready in)'",
    "railway:ci": "pnpm install --frozen-lockfile && pnpm build && pnpm start",
    "railway:ci:min": "NEXT_TELEMETRY_DISABLED=1 pnpm install --frozen-lockfile --reporter=silent > /dev/null 2>&1 && NEXT_TELEMETRY_DISABLED=1 pnpm --silent build > /dev/null 2>&1 && NEXT_TELEMETRY_DISABLED=1 pnpm --silent start:min",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.65",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/papaparse": "^5.5.2",
    "postcss-import": "^16.1.1",
    "ai": "^6.0.169",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.5.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "8.5.12",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
