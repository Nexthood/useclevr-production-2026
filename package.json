{
  "name": "useclever-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "AUTH_TRUST_HOST=true next dev --hostname 0.0.0.0 --port ${PORT:-3000}",
    "build": "next build --webpack",
    "start": "pnpm prod:start",
    "start:next": "next start --hostname 0.0.0.0 --port ${PORT:-8080}",
    "prod:install": "corepack enable && corepack prepare pnpm@10.33.2 --activate && pnpm install --frozen-lockfile",
    "prod:build": "NEXT_TELEMETRY_DISABLED=1 pnpm build && node ./scripts/dist/create-dist.cjs",
    "build:prod": "node ./scripts/dist/create-dist.cjs",
    "prod:start": "pnpm start:dist",
    "prod:local": "NEXT_TELEMETRY_DISABLED=1 AUTH_URL=http://localhost:8080 AUTH_SECRET=${AUTH_SECRET:-$NEXTAUTH_SECRET} AUTH_TRUST_HOST=true HOSTNAME=0.0.0.0 PORT=8080 node -r ./scripts/runtime/load-env.cjs dist/server.js",
    "prod": "pnpm prod:build && echo '✅ Dist is ready! Run \"pnpm start:dist\" to start the server.'",
    "start:dist": "NEXT_TELEMETRY_DISABLED=1 AUTH_URL=${AUTH_URL:-$NEXTAUTH_URL} AUTH_SECRET=${AUTH_SECRET:-$NEXTAUTH_SECRET} AUTH_TRUST_HOST=true HOSTNAME=${HOSTNAME:-0.0.0.0} PORT=${PORT:-8080} node -r ./scripts/runtime/load-env.cjs dist/server.js",
    "analyze:business": "tsx scripts/analysis/analyze-business.ts",
    "test:csv-analyzer": "tsx scripts/analysis/test-csv-analyzer.ts",
    "test:neon": "bash scripts/health/test-neon-connection.sh",
    "clean:dev": "node ./scripts/build/clean-generated.cjs",
    "clean:prod": "node ./scripts/build/clean-generated.cjs --prod",
    "clean:generated": "node ./scripts/build/clean-generated.cjs --generated",
    "clean:all": "node ./scripts/build/clean-generated.cjs --all",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.65",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/papaparse": "^5.5.2",
    "ai": "^6.0.169",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "postcss-import": "^16.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.5.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "8.5.12",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "turbo": "^2.4.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
