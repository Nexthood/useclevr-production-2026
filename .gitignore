# Dependencies
package-lock.json

# Next.js local dev/build cache. Created by `pnpm dev` and `pnpm build`.
.next/
next-env.d.ts
out/
build/

# Environment variables (local only)
.env
.env.local
.env.local.neon
.env.*.local

# Production
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Build artifacts and local caches
.turbo/
tsconfig.tsbuildinfo

# Production output bundle. Created by `pnpm prod:build`.
# The dist folder contains the production deployment bundle
!dist/

# Dependency folders are ignored here so generated output allow-lists cannot re-include them.
**/node_modules
**/node_modules/
**/node_modules/**

# Editor & IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db

# Reports & Data
.reports-data/
**/assets/generated/*
!**/assets/generated/README.md

# AI local
.kilo/*
!.kilo/agent/
!.kilo/agent/*.md
