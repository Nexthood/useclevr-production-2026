# Local development
# PORT controls `pnpm dev`; do not hardcode URLs in app code.
PORT=3000

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-generated-secret-min-32-chars-here
# Optional override only when host inference is not enough:
# AUTH_URL=http://localhost:${PORT}

# AI Providers (Configure at least ONE)
# Priority: Gemini Flash 2.0 > DeepSeek > OpenAI
GEMINI_API_KEY=AIza...                          # Get from https://aistudio.google.com/app/apikey
# OPENAI_API_KEY=sk-...                      # Optional: OpenAI GPT-4o mini
# DEEPSEEK_API_KEY=...                         # Optional: DeepSeek

# Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # Optional
