{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "next.config.js", "tsconfig.json", "tailwind.config.ts", "tailwind.config.js", "drizzle.config.ts"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "build:prod": {
      "dependsOn": ["build"],
      "inputs": ["scripts/dist/create-dist.cjs"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
