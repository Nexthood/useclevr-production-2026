# UseClevr Environment Variables for Railway
# Required for Production Deployment

# ===========================================
# DATABASE (Required)
# ===========================================
# Neon PostgreSQL connection string (get from Neon dashboard)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname
# Or for direct connection (bypasses pooler)
DIRECT_URL=postgresql://user:password@host.neon.tech/dbname

# ===========================================
# AUTH (Required for NextAuth v5)
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-generated-secret-min-32-chars-here

# Railway provides PORT at runtime. Do not set PORT manually unless needed.
# Auth.js can infer the public host from Railway proxy headers because the app sets trustHost.
# Optional override only for custom domains or unusual proxy setups:
# AUTH_URL=https://your-app-name.railway.app

# ===========================================
# AI PROVIDERS (At least one required)
# ===========================================
# Priority: Gemini > DeepSeek > OpenAI
GEMINI_API_KEY=AIza...  # Get from https://aistudio.google.com/app/apikey
# Optional:
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=...

# ===========================================
# UPLOAD STORAGE (Optional - defaults to local)
# ===========================================
# Local storage (default - uploads stored in container)
LOCAL_UPLOAD_DIR=/tmp/useclevr-uploads
LOCAL_UPLOAD_URL=/uploads

# Or S3/R2 (uncomment and configure):
# UPLOAD_PROVIDER=s3  # or 'r2'
# AWS_S3_BUCKET=useclevr-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# R2 (Cloudflare):
# UPLOAD_PROVIDER=r2
# R2_BUCKET=useclevr-uploads
# R2_ENDPOINT=https://...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...

# ===========================================
# OPTIONAL FEATURES
# ===========================================
# Demo mode (skip auth, use mock data)
# DEMO_MODE=true

# ===========================================
# REVERSE PROXY (Railway specific)
# ===========================================
# Trust Railway's reverse proxy headers
TRUST_PROXY=true

# For secure headers validation
# X_FORWARDED_PROTO=https
# X_FORWARDED_HOST=your-app.railway.app

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=...
