{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/assistant/layout,_N_T_/app/assistant/page,_N_T_/app/assistant"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/assistant/__PAGE__",
    "/app/assistant",
    "/app",
    "/_index",
    "/_head"
  ]
}