{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/one-pager/layout,_N_T_/app/one-pager/page,_N_T_/app/one-pager"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/one-pager/__PAGE__",
    "/app/one-pager",
    "/app",
    "/_index",
    "/_head"
  ]
}