{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/referral/layout,_N_T_/app/referral/page,_N_T_/app/referral"
  },
  "segmentPaths": [
