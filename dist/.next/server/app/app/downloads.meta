{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/downloads/layout,_N_T_/app/downloads/page,_N_T_/app/downloads"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/downloads/__PAGE__",
    "/app/downloads",
    "/app",
    "/_index",
    "/_head"
  ]
}