{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/upload/layout,_N_T_/app/upload/page,_N_T_/app/upload"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/upload/__PAGE__",
    "/app/upload",
    "/app",
    "/_index",
    "/_head"
  ]
}