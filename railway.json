{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm prod:build"
  },
  "deploy": {
    "preDeployCommand": "cd dist && npx drizzle-kit push", // Assumes 'dist' is the root, so 'drizzle.config.ts' is at 'dist/drizzle.config.ts'
    "startCommand": "HOSTNAME=0.0.0.0 PORT=${PORT:-8080} node -r ./scripts/runtime/load-env.cjs dist/server.js", // For when repo root is deployment root
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
